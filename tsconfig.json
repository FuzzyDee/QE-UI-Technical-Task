{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "playwright.config.ts",
    "pages/**/*.ts",
    "support/**/*.ts",
    "tests/**/*.ts",
    "features/**/*.ts"
  ]
}